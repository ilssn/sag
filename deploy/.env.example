# ── 端口 ───────────────────────────────────────────────
WEB_PORT=3000
API_PORT=8000

# ── Postgres（zleap 元数据 + zleap-sag pgvector 单库）──
POSTGRES_USER=zleap
POSTGRES_PASSWORD=zleap
POSTGRES_DB=zleap

# ── 应用 ───────────────────────────────────────────────
# 生产务必替换为强随机值（≥32 字节）；沿用默认会拒绝启动。生成：openssl rand -hex 32
ZLEAP_SECRET_KEY=please-change-this-in-production-0123456789
ZLEAP_CORS_ORIGINS=http://localhost:3000
# 公网部署建议置 false（仅首个用户可注册）
ZLEAP_ALLOW_REGISTRATION=true
ZLEAP_SAG_LANGUAGE=zh

# 浏览器访问后端的地址（构建期内联到前端；改动需重建 web 镜像）
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── LLM / Embedding（OpenAI 兼容；不填则问答/抽取不可用）──
ZLEAP_LLM_BASE_URL=
ZLEAP_LLM_API_KEY=
ZLEAP_LLM_MODEL=qwen3.6-flash
ZLEAP_EMBEDDING_MODEL=bge-large-en-v1.5
ZLEAP_EMBEDDING_BASE_URL=
ZLEAP_EMBEDDING_API_KEY=

# ── 稳定性（可选，留空用内置默认）──────────────────────
# ZLEAP_JOB_MAX_ATTEMPTS=3          # 可重试失败最大尝试次数（指数退避）
# ZLEAP_ENGINE_CACHE_SIZE=16        # 引擎槽 LRU 上限
# ZLEAP_ENGINE_WARMUP_COUNT=4       # 启动预热最近使用的信源引擎数
