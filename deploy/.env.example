# ── 端口 ───────────────────────────────────────────────
WEB_PORT=3000
API_PORT=8000

# ── Postgres（muse 元数据 + zleap-sag pgvector 单库）──
POSTGRES_USER=muse
POSTGRES_PASSWORD=muse
POSTGRES_DB=muse

# ── 应用 ───────────────────────────────────────────────
# 生产务必替换为强随机值（≥32 字节）
MUSE_SECRET_KEY=please-change-this-in-production-0123456789
MUSE_CORS_ORIGINS=http://localhost:3000
# 公网部署建议置 false（仅首个用户可注册）
MUSE_ALLOW_REGISTRATION=true
MUSE_SAG_LANGUAGE=zh

# 浏览器访问后端的地址（构建期内联到前端；改动需重建 web 镜像）
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── LLM / Embedding（OpenAI 兼容；不填则问答/抽取不可用）──
MUSE_LLM_BASE_URL=
MUSE_LLM_API_KEY=
MUSE_LLM_MODEL=qwen3.6-flash
MUSE_EMBEDDING_MODEL=bge-large-en-v1.5
MUSE_EMBEDDING_BASE_URL=
MUSE_EMBEDDING_API_KEY=
