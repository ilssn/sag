# ── 应用 ───────────────────────────────────────────────
MUSE_ENVIRONMENT=dev
MUSE_DEBUG=true
# 生产务必替换为强随机值
MUSE_SECRET_KEY=dev-secret-change-me
MUSE_CORS_ORIGINS=http://localhost:3000
# 关闭后仅允许首个用户注册（部署引导），其余 403
MUSE_ALLOW_REGISTRATION=true

# ── muse 元数据库（默认 SQLite 零依赖）────────────────
MUSE_DATABASE_URL=sqlite+aiosqlite:///./.muse/muse.db
# 生产（Postgres）：postgresql+asyncpg://muse:muse@db:5432/muse

# ── 存储 ───────────────────────────────────────────────
MUSE_DATA_DIR=./.muse/zleap
MUSE_UPLOAD_DIR=./.muse/uploads
MUSE_MAX_UPLOAD_MB=25

# ── zleap-sag 后端（默认零依赖 LanceDB）───────────────
MUSE_SAG_VECTOR_PROVIDER=lancedb
# 生产单库（pgvector）时：
# MUSE_SAG_VECTOR_PROVIDER=pgvector
# MUSE_SAG_RELATIONAL_PROVIDER=postgres
# MUSE_SAG_PG_HOST=db
# MUSE_SAG_PG_PORT=5432
# MUSE_SAG_PG_USER=muse
# MUSE_SAG_PG_PASSWORD=muse
# MUSE_SAG_PG_DATABASE=muse
MUSE_SAG_LANGUAGE=zh

# ── LLM（OpenAI 兼容；抽取与答案生成）─────────────────
# 未配置时可启动服务与上传文档，但抽取/问答不可用
MUSE_LLM_BASE_URL=
MUSE_LLM_API_KEY=
MUSE_LLM_MODEL=qwen3.6-flash
MUSE_LLM_TEMPERATURE=0.3

# ── Embedding（缺省复用 LLM 的 key / base_url）────────
MUSE_EMBEDDING_MODEL=bge-large-en-v1.5
MUSE_EMBEDDING_BASE_URL=
MUSE_EMBEDDING_API_KEY=
# MUSE_EMBEDDING_DIMENSIONS=1024

# ── 检索默认 ───────────────────────────────────────────
MUSE_SEARCH_STRATEGY=multi
MUSE_SEARCH_TOP_K=8
