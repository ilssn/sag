# ── 应用 ───────────────────────────────────────────────
ZLEAP_ENVIRONMENT=dev
ZLEAP_DEBUG=true
# 生产务必替换为强随机值
ZLEAP_SECRET_KEY=dev-secret-change-me
ZLEAP_CORS_ORIGINS=http://localhost:3000
# 关闭后仅允许首个用户注册（部署引导），其余 403
ZLEAP_ALLOW_REGISTRATION=true

# ── zleap 元数据库（默认 SQLite 零依赖）────────────────
ZLEAP_DATABASE_URL=sqlite+aiosqlite:///./.data/zleap.db
# 生产（Postgres）：postgresql+asyncpg://zleap:zleap@db:5432/zleap

# ── 存储 ───────────────────────────────────────────────
ZLEAP_DATA_DIR=./.data/engine
ZLEAP_UPLOAD_DIR=./.data/uploads
ZLEAP_MAX_UPLOAD_MB=25

# ── 后台任务与引擎（稳定性）─────────────────────────────
ZLEAP_JOB_CONCURRENCY=2          # 处理并发
ZLEAP_JOB_MAX_ATTEMPTS=3         # 可重试失败的最大尝试次数（指数退避）
ZLEAP_ENGINE_CACHE_SIZE=16       # 引擎槽 LRU 上限（超限逐出最久未用）
ZLEAP_ENGINE_WARMUP_COUNT=4      # 启动时预热最近使用的信源引擎数
# 上传扩展名白名单为内置默认（md/txt/pdf/docx/pptx/xlsx/csv/html/json/图片…）

# ── zleap-sag 后端（默认零依赖 LanceDB）───────────────
ZLEAP_SAG_VECTOR_PROVIDER=lancedb
# 生产单库（pgvector）时：
# ZLEAP_SAG_VECTOR_PROVIDER=pgvector
# ZLEAP_SAG_RELATIONAL_PROVIDER=postgres
# ZLEAP_SAG_PG_HOST=db
# ZLEAP_SAG_PG_PORT=5432
# ZLEAP_SAG_PG_USER=zleap
# ZLEAP_SAG_PG_PASSWORD=zleap
# ZLEAP_SAG_PG_DATABASE=zleap
ZLEAP_SAG_LANGUAGE=zh

# ── LLM（OpenAI 兼容；抽取与答案生成）─────────────────
# 未配置时可启动服务与上传文档，但抽取/问答不可用
ZLEAP_LLM_BASE_URL=
ZLEAP_LLM_API_KEY=
ZLEAP_LLM_MODEL=qwen3.6-flash
ZLEAP_LLM_TEMPERATURE=0.3

# ── Embedding（缺省复用 LLM 的 key / base_url）────────
ZLEAP_EMBEDDING_MODEL=bge-large-en-v1.5
ZLEAP_EMBEDDING_BASE_URL=
ZLEAP_EMBEDDING_API_KEY=
# ZLEAP_EMBEDDING_DIMENSIONS=1024

# ── 检索默认 ───────────────────────────────────────────
ZLEAP_SEARCH_STRATEGY=multi
ZLEAP_SEARCH_TOP_K=8
