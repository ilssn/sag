# ── 应用 ───────────────────────────────────────────────
SAG_ENVIRONMENT=dev
SAG_DEBUG=true
# 生产务必替换为强随机值
SAG_SECRET_KEY=dev-secret-change-me
# 逗号分隔；dev 环境还会自动放行局域网 IP（192.168.x.x 等）
SAG_CORS_ORIGINS=http://localhost:3000
# 关闭后仅允许首个用户注册（部署引导），其余 403
SAG_ALLOW_REGISTRATION=true

# ── sag 元数据库（默认 SQLite 零依赖）────────────────
SAG_DATABASE_URL=sqlite+aiosqlite:///./.data/sag.db
# 生产（Postgres）：postgresql+asyncpg://sag:sag@db:5432/sag

# ── 存储 ───────────────────────────────────────────────
SAG_DATA_DIR=./.data/engine
SAG_UPLOAD_DIR=./.data/uploads
SAG_MAX_UPLOAD_MB=25

# ── 后台任务与引擎（稳定性）─────────────────────────────
SAG_JOB_CONCURRENCY=2          # 处理并发
SAG_DOCUMENT_EXTRACT_CONCURRENCY=5  # 每个文档的 chunk 抽取并发
SAG_DOCUMENT_CHUNK_MAX_TOKENS=1000  # 每个切片的最大 token 数
SAG_DOCUMENT_CHUNK_MODE=standard    # standard / heading_strict
SAG_JOB_MAX_ATTEMPTS=3         # 可重试失败的最大尝试次数（指数退避）
SAG_ENGINE_CACHE_SIZE=16       # 引擎槽 LRU 上限（超限逐出最久未用）
SAG_ENGINE_WARMUP_COUNT=4      # 启动时预热最近使用的信源引擎数
# 上传扩展名白名单为内置默认（md/txt/pdf/docx/pptx/xlsx/csv/html/json/图片…）

# ── zleap-sag 后端（默认零依赖 LanceDB）───────────────
SAG_SAG_VECTOR_PROVIDER=lancedb
# 生产单库（pgvector）时：
# SAG_SAG_VECTOR_PROVIDER=pgvector
# SAG_SAG_RELATIONAL_PROVIDER=postgres
# SAG_SAG_PG_HOST=db
# SAG_SAG_PG_PORT=5432
# SAG_SAG_PG_USER=sag
# SAG_SAG_PG_PASSWORD=sag
# SAG_SAG_PG_DATABASE=sag
SAG_SAG_LANGUAGE=zh

# ── LLM（OpenAI 兼容；抽取与答案生成）─────────────────
# 未配置时可启动服务与上传文档，但抽取/问答不可用
SAG_LLM_BASE_URL=
SAG_LLM_API_KEY=
SAG_LLM_MODEL=qwen3.6-flash
SAG_LLM_TEMPERATURE=0.3
SAG_LLM_TIMEOUT_MS=60000
SAG_LLM_MAX_RETRIES=2

# ── Embedding（缺省复用 LLM 的 key / base_url）────────
SAG_EMBEDDING_MODEL=bge-large-en-v1.5
SAG_EMBEDDING_BASE_URL=
SAG_EMBEDDING_API_KEY=
# SAG_EMBEDDING_DIMENSIONS=1024

# ── 检索默认 ───────────────────────────────────────────
SAG_SEARCH_STRATEGY=multi
SAG_SEARCH_TOP_K=8
