{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SAG",
  "version": "1.2.2",
  "identifier": "com.zleap.sag",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "node ./scripts/stage-frontend.mjs",
    "frontendDist": "../dist-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: http://127.0.0.1:*",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*",
        "worker-src": "'self' blob:",
        "media-src": "'self' blob: http://127.0.0.1:*"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../binaries/sidecar": "sidecar"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "./entitlements.plist",
      "signingIdentity": null
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBKEY_BEFORE_FIRST_RELEASE",
      "endpoints": [
        "https://github.com/ilssn/sag/releases/latest/download/latest.json"
      ]
    }
  }
}
