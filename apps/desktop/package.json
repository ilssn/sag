{
  "name": "sag-desktop",
  "private": true,
  "version": "1.2.2",
  "description": "SAG 桌面壳（Electron + FastAPI sidecar）",
  "main": "dist-electron/main.js",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "node ./scripts/require-npm.cjs",
    "typecheck": "tsc --noEmit",
    "build:main": "tsc",
    "stage:frontend": "node ./scripts/stage-frontend.mjs",
    "stage:sidecar": "python3 ./scripts/build_sidecar.py",
    "check:versions": "node ./scripts/check-versions.mjs",
    "test": "vitest run",
    "dev": "npm run build:main && electron . --dev",
    "build": "npm run build:main && electron-builder",
    "build:dir": "npm run build:main && electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "^22",
    "electron": "^33",
    "electron-builder": "^25",
    "typescript": "^5.7",
    "vitest": "^4"
  },
  "dependencies": {
    "electron-updater": "^6"
  }
}
