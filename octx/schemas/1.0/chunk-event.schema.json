{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCTX Chunk-Event Relation 1.0",
  "type": "object",
  "required": ["chunk_id", "event_id"],
  "properties": {
    "chunk_id": {
      "$ref": "#/$defs/uuidv7"
    },
    "event_id": {
      "$ref": "#/$defs/uuidv7"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "uuidv7": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  }
}
