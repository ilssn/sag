# Docker Compose 可直接使用内置默认值；仅在需要自定义时复制本文件为 .env。

# ── 端口 ───────────────────────────────────────────────
WEB_PORT=3000
API_PORT=8000
# 本机默认只监听回环地址；局域网/服务器部署改为 0.0.0.0。
BIND_ADDRESS=127.0.0.1

# ── 本地快速启动 ───────────────────────────────────────
SAG_ENVIRONMENT=dev
SAG_CORS_ORIGINS=http://localhost:3000
# 关闭传统邮箱注册接口；本地身份引导不受此项影响。
SAG_ALLOW_REGISTRATION=false
SAG_SAG_LANGUAGE=zh

# 生产部署必须设置强随机值（生成命令：openssl rand -hex 32）。
# 本地 dev 留空时，Compose 会使用只适合本机的开发密钥。
SAG_SECRET_KEY=

# 浏览器访问后端的地址（构建期内联；修改后需重建 web 镜像）。
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Web 默认开启页内窗口缩放；桌面客户端构建时设为 false。
NEXT_PUBLIC_ENABLE_WINDOW_SCALING=true

# ── LLM / Embedding（也可启动后在设置页填写）──
SAG_LLM_PROVIDER=openai
SAG_LLM_BASE_URL=https://api.302ai.cn/v1
SAG_LLM_API_KEY=
SAG_LLM_MODEL=qwen3.6-flash
# Anthropic / Gemini 原生接入时将 SAG_LLM_PROVIDER 改为对应值，Base URL 留空使用官方端点。
SAG_EMBEDDING_MODEL=bge-large-en-v1.5
SAG_EMBEDDING_BASE_URL=https://api.302ai.cn/v1
SAG_EMBEDDING_API_KEY=

# ── 文档解析（PDF 优先 MinerU；未配置或失败时回退 MarkItDown）────
SAG_DOCUMENT_PARSER=auto
SAG_MINERU_BASE_URL=https://api.302ai.cn
SAG_MINERU_API_KEY=
SAG_MINERU_VERSION=2.5

# ── Postgres 生产覆盖（compose.postgres.yaml）───────────
POSTGRES_USER=sag
# 生产覆盖必填；建议使用：openssl rand -hex 24
POSTGRES_PASSWORD=
POSTGRES_DB=sag

# ── 稳定性（可选，取消注释后生效）──────────────────────
# SAG_JOB_MAX_ATTEMPTS=3
# SAG_ENGINE_CACHE_SIZE=16
# SAG_ENGINE_WARMUP_COUNT=4
# SAG_MINERU_POLL_TIMEOUT=300
